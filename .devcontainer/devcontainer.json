{
  "name": "Ansible MCP Server Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:Australia/Sydney}"
    }
  },
  "runArgs": [
    "--env-file",
    ".devcontainer/devcontainer.env",
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--privileged"
  ],
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2.12.2": {}
  },
  "postCreateCommand": "sudo /workspace/.devcontainer/init-firewall.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "Anthropic.claude-code",
        "redhat.vscode-yaml",
        "ms-azuretools.vscode-azure-github-copilot",
        "golang.go"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[go]": {
          "editor.defaultFormatter": "golang.go",
          "editor.formatOnSave": true
        },
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "go.toolsManagement.autoUpdate": true,
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          },
          "zsh": {
            "path": "zsh"
          }
        }
      }
    }
  },
  "remoteUser": "node",
  "mounts": [
    "source=claude-code-bashhistory,target=/commandhistory,type=volume",
    "source=claude-code-config,target=/home/node/.claude,type=volume"
  ],
  "remoteEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
    "CLAUDE_GITHUB_MCP_ENABLED": "true",
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}",
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "ANSIBLE_HUB_SAAS_TOKEN": "${localEnv:ANSIBLE_HUB_SAAS_TOKEN}",
    "ANSIBLE_HUB_TARGET": "${localEnv:ANSIBLE_HUB_TARGET}",
    "ANSIBLE_AAP_URL": "${localEnv:ANSIBLE_AAP_URL}",
    "ANSIBLE_AAP_AUTH_MODE": "${localEnv:ANSIBLE_AAP_AUTH_MODE}",
    "ANSIBLE_AAP_TOKEN": "${localEnv:ANSIBLE_AAP_TOKEN}",
    "ANSIBLE_AAP_USERNAME": "${localEnv:ANSIBLE_AAP_USERNAME}",
    "ANSIBLE_AAP_PASSWORD": "${localEnv:ANSIBLE_AAP_PASSWORD}"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace/ansible-mcp-server"
}
