# Secrets for the Ansible MCP Server devcontainer.
# This file is gitignored — never commit real values.
# Copy this file, fill in values, and keep it local.

# GitHub
GITHUB_TOKEN=

# Anthropic (Claude Code)
ANTHROPIC_API_KEY=

# Ansible Automation Hub SaaS (cloud.redhat.com)
# Get your offline token from: https://console.redhat.com/ansible/automation-hub/token
ANSIBLE_HUB_SAAS_TOKEN=

# Hub target: saas | aap | both
ANSIBLE_HUB_TARGET=saas

# On-prem AAP (leave blank if using SaaS only)
ANSIBLE_AAP_URL=
ANSIBLE_AAP_AUTH_MODE=token
ANSIBLE_AAP_TOKEN=
ANSIBLE_AAP_USERNAME=
ANSIBLE_AAP_PASSWORD=
